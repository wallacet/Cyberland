#!/usr/bin/env sh

set -eu

# Shipped demo mods (mods/Cyberland.Demo*) must keep "disabled": true in manifest.json on commit.
check_demo_mod_manifests_disabled() {
  if [ "${CYBERLAND_ALLOW_DEMO_MODS_ENABLED:-0}" = "1" ]; then
    echo "CYBERLAND_ALLOW_DEMO_MODS_ENABLED=1 set; skipping demo-manifest guard."
    return 0
  fi

  for path in \
    mods/Cyberland.Demo/manifest.json \
    mods/Cyberland.Demo.Pong/manifest.json \
    mods/Cyberland.Demo.Snake/manifest.json \
    mods/Cyberland.Demo.BrickBreaker/manifest.json
  do
    if [ -z "$(git ls-files --cached -- "$path" 2>/dev/null)" ]; then
      continue
    fi
    if ! content=$(git show ":$path" 2>/dev/null); then
      continue
    fi
    if printf '%s\n' "$content" | grep -qE '"disabled"[[:space:]]*:[[:space:]]*true'; then
      continue
    fi
    echo "ERROR: Commit blocked — demo mod manifest must keep demos disabled in the index."
    echo "  File: $path"
    echo "  Staged manifest must contain: \"disabled\": true"
    echo "  (Turn demos on locally for testing; do not commit enabled manifests.)"
    echo "  Bypass (use sparingly): CYBERLAND_ALLOW_DEMO_MODS_ENABLED=1 git commit ..."
    echo "  Or: git commit --no-verify"
    exit 1
  done
}

check_demo_mod_manifests_disabled

MAX_MB="${CYBERLAND_MAX_FILE_MB:-4}"
ALLOW_LARGE="${CYBERLAND_ALLOW_LARGE_FILES:-0}"

if [ "$ALLOW_LARGE" = "1" ]; then
  echo "CYBERLAND_ALLOW_LARGE_FILES=1 set; skipping large-file guard."
  exit 0
fi

MAX_BYTES=$((MAX_MB * 1024 * 1024))

staged_files=$(git diff --cached --name-only --diff-filter=AM)
if [ -z "$staged_files" ]; then
  exit 0
fi

violations=""

for file in $staged_files; do
  if [ ! -f "$file" ]; then
    continue
  fi

  size=$(wc -c < "$file" | tr -d '[:space:]')
  if [ "$size" -gt "$MAX_BYTES" ]; then
    mib=$(awk "BEGIN { printf \"%.2f\", $size / 1048576 }")
    violations="${violations}\n- ${file} (${mib} MiB)"
  fi
done

if [ -n "$violations" ]; then
  echo "ERROR: Commit blocked by large-file guard."
  printf "Files above %s MiB:\n%b\n" "$MAX_MB" "$violations"
  echo ""
  echo "Use GitHub Releases asset bundles for large media under mods/*/Content."
  echo "One-off bypass (use sparingly): git commit --no-verify"
  echo "Maintainer local override: CYBERLAND_ALLOW_LARGE_FILES=1 git commit ..."
  echo "Optional threshold override: CYBERLAND_MAX_FILE_MB=8 git commit ..."
  exit 1
fi

exit 0
