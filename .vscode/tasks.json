{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Cyberland: Run",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/Cyberland.Host/Cyberland.Host.csproj",
        "-c",
        "Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "group": "none",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "detail": "Build and run Cyberland.Host (Debug). Same as run-cyberland skill.",
      "icon": {
        "id": "play",
        "color": "terminal.ansiGreen"
      }
    },
    {
      "label": "Cyberland: Test Engine",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/tests/Cyberland.Engine.Tests/Cyberland.Engine.Tests.csproj",
        "-c",
        "Debug",
        "/p:CollectCoverage=true"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "detail": "Engine unit tests with coverlet (100% line coverage gate). Same as test-cyberland-engine skill.",
      "icon": {
        "id": "beaker",
        "color": "terminal.ansiCyan"
      }
    },
    {
      "label": "Cyberland: Publish Release",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/Publish-Cyberland.ps1",
        "-Configuration",
        "Release"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "detail": "Framework-dependent portable publish (artifacts/publish/.../release/). Requires .NET 8 runtime. Use a (win-x64) RID task when you need platform-specific native dependencies without bundling CoreCLR.",
      "icon": {
        "id": "package",
        "color": "terminal.ansiYellow"
      }
    },
