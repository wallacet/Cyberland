# Build outputs — all SDK output lives under repo-root artifacts/ (Directory.Build.props:
# UseArtifactsOutput + ArtifactsPath). Includes bin/, obj/, and publish/ there—not per-project bin/obj.
/artifacts/

# Stray bin/obj if a project opts out of artifacts layout or uses other tools
**/bin/
**/obj/
**/out/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Compiled / native binaries (catch stragglers outside ignored build dirs)
*.o
*.obj
*.exe
*.dll
*.dylib
*.so
*.a
*.lib
*.wasm

# Packaging
*.nupkg
*.snupkg

# Testing & coverage
TestResults/
[Tt]est[Rr]esult*/
*.trx
coverage*
*.coverage
*.coveragexml
**/coverage.cobertura.xml

# Logs and temp
*.log
*.tmp
*.temp
*.cache
*.dmp

# Legacy / tool-generated
build/
dist/
node_modules/
vendor/
project.lock.json
**/appsettings.*.local.json
*.pfx
